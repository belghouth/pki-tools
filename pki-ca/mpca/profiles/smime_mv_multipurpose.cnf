; S/MIME Mailbox-Validated — Multipurpose
; Complies with CA/B Forum S/MIME Baseline Requirements (Mailbox-Validated, Multipurpose).
;
; The meta section is parsed by mpca_factory.php and ignored by OpenSSL.
; The leaf_ext section and any referenced sections go to openssl ca -extfile.
; The {{SAN}} placeholder is substituted at runtime with the rfc822Name value.

[meta]
label         = S/MIME MV — Multipurpose
description   = Mailbox-validated certificate for email signing and encryption (CA/B Forum S/MIME BR §7)
sub_ca        = smime
san_type      = email
validity_days = 1095
key_types     = rsa,ec
order         = 10

[leaf_ext]
basicConstraints       = critical,CA:false
keyUsage               = critical,digitalSignature,nonRepudiation,keyEncipherment
extendedKeyUsage       = emailProtection
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid:always
crlDistributionPoints  = URI:http://pki.thameur.org/mpca/smime_ca.crl
authorityInfoAccess    = caIssuers;URI:http://pki.thameur.org/mpca/smime_ca.crt
certificatePolicies    = @cp_local, @cp_cabf
subjectAltName         = {{SAN}}

[cp_local]
policyIdentifier = 2.16.788.1.99.1.10
CPS.1            = https://pki.thameur.org/mpca/cps.html

[cp_cabf]
policyIdentifier = 2.23.140.1.5.1.1
